custom_minimum_size = Vector2(512, 0)
layout_mode = 2
text = "Each round players split ships between exploration and combat.
- Exploring ships each bring back 1 gold at the end of the round (guaranteed income).
- Ships kept at home are used for combat.
- Splitting ships is a tradeoff between guaranteeed income and combat strength"
autowrap_mode = 3

